#!/usr/bin/env bash

set -euo pipefail

MSG_FILE="$1"

name="$(git config user.name || true)"
email="$(git config user.email || true)"

if [[ -z "$name" || -z "$email" ]]; then
  echo "Git user.name or user.email is not set."
  echo "Set them before committing."
  exit 1
fi

signoff="Signed-off-by: $name <$email>"

if ! grep -qi "^Signed-off-by:[[:space:]]*$name[[:space:]]*<$email>$" "$MSG_FILE"; then
  printf "\n%s\n" "$signoff" >> "$MSG_FILE"
fi